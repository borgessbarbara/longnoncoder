// Nextflow config file for testing the transcript annotation module

// Global default params
params {
    // Test parameters
    outdir = './results'
    
    // Process-specific parameters
    ensembl_version = 113
}

// Process configuration
process {
    // Default process settings
    cpus = 2
    memory = 4.GB
    time = 1.h
    
    // Process-specific settings
    withName: TRANSCRIPT_ANNOTATION {
        cpus = 2
        memory = 6.GB
        time = 2.h
        ext.args = '--ensembl_version 113'
        publishDir = [
            path: "${params.outdir}/transcript_annotation",
            mode: 'copy',
            saveAs: { filename -> filename.equals('versions.yml') ? null : filename }
        ]
    }
}

// Execution profiles
profiles {
    conda {
        conda.enabled = true
        docker.enabled = false
        singularity.enabled = false
    }
    
    docker {
        docker.enabled = true
        conda.enabled = false
        singularity.enabled = false
    }
    
    singularity {
        singularity.enabled = true
        conda.enabled = false
        docker.enabled = false
    }
    
    test {
        // Test profile with reduced resources
        process.cpus = 1
        process.memory = 2.GB
        process.time = 30.min
    }
}

// Manifest
manifest {
    name = 'transcript-annotation-test'
    description = 'Test pipeline for transcript annotation module'
    version = '1.0.0'
    nextflowVersion = '>=22.10.1'
}

// Cleanup options
cleanup = false

// Report options
report {
    enabled = true
    file = "${params.outdir}/pipeline_report.html"
}

timeline {
    enabled = true
    file = "${params.outdir}/timeline.html"
}

trace {
    enabled = true
    file = "${params.outdir}/trace.txt"
}