params {
    config_profile_name        = 'Large profile'
    config_profile_description = 'Profile for large fastq and bam files'
}

process {
    withLabel:process_single {
        cpus   =  1
        memory = 20.GB
        time   = 8.h
    }
    withLabel:process_low {
        cpus   =  1
        memory = 10.GB
        time   = 4.h
    }
    withLabel:process_medium {
        cpus   =  18
        memory = 40.GB
        time   = 8.h
    }
    withLabel:process_high {
        cpus   =  10
        memory = 100.GB
        time   = 20.h
    }
    withLabel:process_long {
        time   = 48.h
    }
    withLabel:process_high_memory {
        cpus = 6
        memory = 600.GB
        time = 12.h
    }
}