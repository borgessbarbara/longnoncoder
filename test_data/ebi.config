params {

    // Input data
    // TODO nf-core: Specify the paths to your test data on nf-core/test-datasets
    // TODO nf-core: Give any required params for the test so that command line flags are not needed
    input           = "$projectDir/test_data/test_ebi.csv"

    // Skips
    skip_qc            = false
    skip_filtering     = false
    skip_alignment     = false
    skip_alignment_qc  = false
    skip_class         = false

    // Filtering raw reads options
    // Filtering options
    minqual                    = 5
    minlen                     = 200
    maxlen                     = 2147483647
    maxgc                      = 0.6
    mingc                      = 0.4
    headcrop                   = 0
    tailcrop                   = 0

    // Alignment options
    reference                  = "/pfs/10/project/bw24d008/pipelines/data_babi/references/Homo_sapiens.GRCh38.dna_sm.primary_assembly.fa"
    bam_format                 = true
    cigar_paf_format           = false
    cigar_bam                  = false

    //Bambu options
    annotation                 = "/pfs/10/project/bw24d008/pipelines/data_babi/references/Homo_sapiens.GRCh38.114.chr.gtf"

    // Coding potential options
    organism                   = 'Homo_sapiens'
}
